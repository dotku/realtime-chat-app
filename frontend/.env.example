# Copy this file to .env.local for local development
# For production, set these in your Vercel project settings (Environment Variables)

# Backend API base URL (HTTP/HTTPS)
VITE_API_URL=https://your-backend.koyeb.app

# Backend WebSocket URL (WSS for production, WS for local)
VITE_WS_URL=wss://your-backend.koyeb.app

# Auth0 — Applications > your app > Settings in the Auth0 Dashboard
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_client_id

# ---------- Local development ----------
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000
