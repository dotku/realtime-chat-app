# Copy this file to .env for local development
# For production (Koyeb), set these as environment variables in the service settings

# PostgreSQL connection string
# - Local Docker:  postgresql://chatuser:chatpass@db:5432/chatdb
# - Neon (cloud):  postgresql://user:pass@ep-xxx-xxx.us-east-2.aws.neon.tech/chatdb?sslmode=require
DATABASE_URL=postgresql://chatuser:chatpass@localhost:5432/chatdb

# Comma-separated list of allowed CORS origins (exact match)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Production example:
# ALLOWED_ORIGINS=https://chat.jytech.us

# Optional: regex pattern for wildcard subdomain support
# Mutually exclusive with ALLOWED_ORIGINS — use one or the other
# Example: allow all *.jytech.us subdomains
# CORS_ORIGIN_REGEX=https://.*\.jytech\.us

# Vercel AI Gateway API key — required for AI chat features (@modelName mentions)
# Get your key at: https://vercel.com/ai-gateway
# BYOK (Bring Your Own Key) — you pay providers directly at their rates
# GATEWAY_API_KEY=your_vercel_ai_gateway_key_here
